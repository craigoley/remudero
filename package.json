{
  "name": "remudero",
  "version": "0.1.0",
  "description": "Plan-stewarding orchestration harness for Claude Code",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "rmd": "bin/rmd"
  },
  "files": [
    "bin",
    "src",
    "settings",
    "hooks",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.22.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test --import tsx \"test/**/*.test.ts\"",
    "lint-plan": "tsx src/run-task.ts lint-plan",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "jscpd": "jscpd src --config .jscpd.json",
    "claims": "node scripts/claims-check.mjs",
    "learnings-index": "node scripts/generate-learnings-index.mjs",
    "learnings-index:check": "node scripts/generate-learnings-index.mjs --check",
    "plan-index": "node scripts/generate-plan-index.mjs",
    "plan-index:check": "node scripts/generate-plan-index.mjs --check",
    "learnings-assert": "node scripts/learnings-assert-check.mjs",
    "learnings-assert:check": "node scripts/learnings-assert-check.mjs --check",
    "spike": "tsx src/spike.ts",
    "commitlint": "commitlint",
    "changelog": "commit-and-tag-version"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.210",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@stryker-mutator/core": "^9.6.1",
    "@swc/core": "^1.15.43",
    "@types/node": "^22.20.1",
    "commit-and-tag-version": "^13.0.0",
    "dependency-cruiser": "^18.1.0",
    "jscpd": "^5.0.12"
  },
  "overrides": {
    "qs": "^6.15.3"
  },
  "commit-and-tag-version": {
    "skip": {
      "commit": true,
      "tag": true
    }
  }
}
