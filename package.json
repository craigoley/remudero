{
  "name": "remudero",
  "version": "0.0.0-pre-alpha",
  "description": "Plan-stewarding orchestration harness for Claude Code",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "rmd": "bin/rmd"
  },
  "files": [
    "bin",
    "src",
    "settings",
    "hooks",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.22.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test --import tsx \"test/**/*.test.ts\"",
    "lint-plan": "tsx src/run-task.ts lint-plan",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "spike": "tsx src/spike.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.210",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@types/node": "^22.20.1",
    "dependency-cruiser": "^18.1.0"
  }
}
