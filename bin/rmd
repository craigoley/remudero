#!/usr/bin/env bash
# rmd — Remudero CLI (proto-runner era). Thin wrapper; all logic lives in TS.
#
# The full, authoritative command list lives in ONE place — the COMMANDS registry in
# src/run-task.ts — not here. Run `rmd --help` for every command, or `rmd <cmd> --help`
# for one (both generated from that registry, W1-T47). This header used to hand-duplicate
# that list in prose and had already drifted from what main() actually dispatched
# (missing dep-review/sweep/fix, stale flags on drain/daemon) — exactly the failure mode
# a single source of truth is meant to prevent. Do not re-add a duplicate list here.
set -euo pipefail
# Resolve the real package root even when invoked through symlinks (npm link /
# a global install both put `rmd` on PATH as a symlink chain, not a copy).
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  LINK_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$LINK_DIR/$SOURCE"
done
DIR="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"
exec "$DIR/node_modules/.bin/tsx" "$DIR/src/run-task.ts" "$@"
