node_modules
local/
*.pat
FINDINGS-local*

# build output
dist/
*.tsbuildinfo

# generated coverage reports (W1-T25 coverage-ratchet gate consumes coverage/lcov.info,
# regenerated fresh every run — never committed)
coverage/

# generated mutation-testing reports (W1-T96 mutation-ratchet gate consumes
# reports/mutation/mutation.json, regenerated fresh every run — never committed) + Stryker's
# own scratch sandbox directory
reports/mutation/
.stryker-tmp/

# Stryker's incremental-mode cache (W1-T108: restored/saved by ci.yml's mutation-ratchet job
# via actions/cache, never committed — a stale local copy must never be mistaken for CI's)
reports/stryker-incremental.json

# generated refactor-campaign reports (W2-T3 — jscpd/depcruise/npm-audit JSON, regenerated fresh
# by the refactor-campaign CI job every run — never committed; scripts/refactor-campaign.mjs
# compares them against the checked-in scripts/*-baseline.json floors)
reports/jscpd/
reports/depcruise/
reports/audit/

# os / editor
.DS_Store

# runtime exhaust (W1-T256): the daemon/serve write these into their OWN working tree every run —
# pure append-only/derived state (the ledger, status/marker caches, the clarification-question
# backlog, launchd's stdout/stderr logs), never committed. Un-ignored they read as "dirt" in a
# `git status --porcelain`, which (pre-W1-T255) crash-looped the daemon on restart; ignored, this
# exhaust never counts against a clean tree.
state/
plan/questions.ndjson
*.log
