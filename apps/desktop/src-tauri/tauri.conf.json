{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Remudero",
  "version": "0.1.0",
  "identifier": "sh.remudero.desktop",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build:web",
    "beforeDevCommand": "npm run build:web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Remudero",
        "url": "index.html",
        "width": 1100,
        "height": 760,
        "visible": false,
        "hiddenTitle": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    },
    "withGlobalTauri": false,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["remudero"]
      }
    }
  }
}
